# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
*.egg-info/
src/*.egg-info/
**/build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── macOS / Windows ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
*Zone.Identifier

# ── Data — download from Kaggle competition page ──────────────────────────────
# https://www.kaggle.com/competitions/esa-adb-challenge/data
# Place files in data/raw/ after downloading.
data/raw/*.parquet
raw_data/
*.zip

# ── Processed arrays — regenerated by running notebooks 01–02 ─────────────────
data/processed/

# ── Tool / test caches ────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Saved models ─────────────────────────────────────────────────────────────
models/*.pkl
models/*.json
models/*.h5
models/*.joblib
!models/.gitkeep
*.pickle
*.pckl

# ── Submissions — generated by running notebooks 03–04 ────────────────────────
submissions/*.parquet

# ── Results ───────────────────────────────────────────────────────────────────
results/
!results/scores/.gitkeep

# ── Credentials ───────────────────────────────────────────────────────────────
.env
.env.yaml
.credentials
secrets.toml
