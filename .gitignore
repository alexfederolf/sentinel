# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyc
*.egg-info/
src/*.egg-info/
**/build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── macOS / Windows ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
*Zone.Identifier

# ── Data — download from Kaggle competition page ──────────────────────────────
# https://www.kaggle.com/competitions/esa-adb-challenge/data
# Place files in data/raw/ after downloading.
data/raw/*.parquet
raw_data/
*.zip

# ── Processed arrays ──────────────────────────────────────────────────────────
# Ignore the contents (not the directory), so we can whitelist specific files.
data/processed/*

# FE demo slice — used by api/fast.py + notebooks FE pipeline.
!data/processed/test_api_fe.npy
!data/processed/y_test_api_fe.npy

# ── Tool / test caches ────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp


# ── Saved models ─────────────────────────────────────────────────────────────
models/*.keras
models/*.pkl
models/*.json
models/*.h5
models/*.joblib
!models/.gitkeep

# Keep the API runtime artefacts tracked so the Docker image ships with them.
#!models/pca.pkl
#!models/scaler.pkl

# FE 46ch model + sidecar (loaded by load_fe46_artefacts).
!models/pca_fe_46ch.pkl
!models/fe_46ch_*.json

# ── Results ───────────────────────────────────────────────────────────────────
results/
!results/scores/.gitkeep

# ── Credentials ───────────────────────────────────────────────────────────────
.env
.env.yaml
.credentials
secrets.toml

# ── Miscellaneous ─────────────────────────────────────────────────────────────
reports/
notebooks/cache/
.envrc
.env.yaml
.claude/
