    n_det = int(pred_in_seg.sum())
    event_rows.append({
        'start'        : seg['start'],
        'end'          : seg['end'],
        'length'       : seg['length'],
        'detected'     : n_det > 0,
        'n_pred_in_seg': n_det,
        'hit_rate'     : n_det / seg['length'],
    })

event_df   = pd.DataFrame(event_rows)
